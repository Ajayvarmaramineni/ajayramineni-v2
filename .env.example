# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# Copy this to frontend/.env.local and fill in your values

# URL of the running FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000


# ── Backend (FastAPI) ──────────────────────────────────────────────────────────
# Copy relevant vars to backend/.env (not committed)

# Optional: Supabase connection (for persistent storage — not required for MVP)
# SUPABASE_URL=https://xyzcompany.supabase.co
# SUPABASE_KEY=your-anon-or-service-key

# Optional: Clerk auth (frontend handles this via ClerkProvider)
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
